{
  "name": "xhs-favorites",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Persistent-profile XiaoHongShu favorites CLI and MCP server built on Playwright.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ONEMULE/xhs-favorites.git"
  },
  "homepage": "https://github.com/ONEMULE/xhs-favorites#readme",
  "bugs": {
    "url": "https://github.com/ONEMULE/xhs-favorites/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "xiaohongshu",
    "rednote",
    "playwright",
    "mcp",
    "favorites"
  ],
  "bin": {
    "xhs-favorites": "./src/cli.js",
    "xhs-favorites-mcp": "./src/mcp.js"
  },
  "scripts": {
    "test": "node --test",
    "doctor": "node ./src/cli.js doctor",
    "login": "node ./src/cli.js login",
    "start:mcp": "node ./src/mcp.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "playwright": "1.59.1",
    "zod": "4.3.6"
  }
}
